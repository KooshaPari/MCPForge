# Phenotype-org standard .gitignore — Python
# Source: https://github.com/KooshaPari/phenotype-tooling/blob/main/templates/gitignore-python

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
ENV/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Repo-specific additions (preserved from prior .gitignore)
!.env.example
.agileplus
.env
.env.*
.goosehints
.mcp.json
*.diff
*~
CLAUDE.md*
coverage
integrationtests/workspaces/clangd/.cache
integrationtests/workspaces/clangd/clean_program
integrationtests/workspaces/clangd/compile_commands.json
integrationtests/workspaces/clangd/program
integrationtests/workspaces/clangd/src/*.o
mcp-language-server
node_modules
target
test-output
